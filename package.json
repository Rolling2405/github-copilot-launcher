{
  "name": "github-copilot-launcher",
  "version": "0.1.0",
  "description": "A visual command menu for GitHub Copilot CLI — browse, search, and launch any copilot command without memorizing a thing",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "copilot-launcher": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "copilot",
    "cli",
    "launcher",
    "menu",
    "terminal",
    "github",
    "ai",
    "command-discovery"
  ],
  "author": "Rolling2405",
  "license": "MIT",
  "dependencies": {
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ]
}
